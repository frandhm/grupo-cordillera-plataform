# ==========================================
# GRUPO CORDILLERA - PLATAFORMA (NX MONOREPO)
# ==========================================

# --- DEPENDENCIAS Y SALIDAS DE CONSTRUCCIÓN ---
node_modules/
/dist/
/build/
/tmp/
/out-tsc/
/coverage/

# --- NX & HERRAMIENTAS DE DESARROLLO ---
.nx/cache/
.nx/workspace-data/
.angular/cache/
.claude/
/.sass-cache/

# --- CONFIGURACIÓN LOCAL Y SECRETOS (CRÍTICO) ---
# No subir credenciales de DB ni configuraciones personales
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- IDEs (VS Code / JetBrains / Otros) ---
# Esto evita que tus temas o extensiones personales afecten a tus compañeros
.vscode/
.idea/
*.swp
*.suo
*.ntvs*
*.njsproj
*.sln
*.sublime-workspace
.project
.classpath
.settings/

# --- DOCKER ---
# Ignorar la carpeta donde Postgres guarda los datos físicos (si la usas)
pgdata/
docker/data/

# --- LOGS Y DEPURACIÓN ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- SISTEMA OPERATIVO ---
.DS_Store
Thumbs.db
/libpeerconnection.log

# --- OTROS ---
/connect.lock
testem.log
/typings/